of Full-Scale Wastewater Treatment
Plants Identifies Sentinel Antibiotic Resistance Gene Families for
Monitoring Reclaimed Wastewater and Treated Sludge</article-title></title-group><contrib-group id="CONTRIB-GROUP-d14e22-autogenerated"><contrib id="ath1" contrib-type="author"><contrib-id contrib-id-type="paragon-plus" authenticated="true">7883244</contrib-id><contrib-id contrib-id-type="orcid" authenticated="true">https://orcid.org/0000-0002-2406-8910</contrib-id><name><surname>Brown</surname><given-names>Liam P</given-names></name><xref rid="aff1" ref-type="aff"/></contrib><contrib id="ath2" contrib-type="author"><contrib-id contrib-id-type="paragon-plus" authenticated="true">7883040</contrib-id><name><surname>Marizzi</surname><given-names>Anna</given-names></name><xref rid="aff2" ref-type="aff"/></contrib><contrib id="ath3" contrib-type="author"><contrib-id contrib-id-type="paragon-plus" authenticated="true">6604990</contrib-id><name><surname>Borrego</surname><given-names>Carles M</given-names></name><xref rid="aff3" ref-type="aff"/><xref rid="aff4" ref-type="aff"/></contrib><contrib id="ath4" contrib-type="author"><contrib-id contrib-id-type="paragon-plus" authenticated="true">7883050</contrib-id><name><surname>Gionchetta</surname><given-names>Giulia</given-names></name><xref rid="aff2" ref-type="aff"/></contrib><contrib id="ath5" contrib-type="author"><contrib-id contrib-id-type="paragon-plus" authenticated="true">6452227</contrib-id><contrib-id contrib-id-type="orcid" authenticated="true">https://orcid.org/0009-0002-9476-7044</contrib-id><name><surname>Zhengzheng</surname><given-names>Zhao</given-names></name><xref rid="aff5" ref-type="aff"/></contrib><contrib id="ath6" contrib-type="author"><contrib-id contrib-id-type="paragon-plus" authenticated="true">6708709</contrib-id><contrib-id contrib-id-type="orcid" authenticated="true">https://orcid.org/0000-0002-9188-4133</contrib-id><name><surname>Carneiro</surname><given-names>Rodrigo B</given-names></name><xref rid="aff6" ref-type="aff"/></contrib><contrib id="ath7" contrib-type="author"><contrib-id contrib-id-t